# Application
APP_NAME=Polymarket Trading Bot
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Database (Milestone 4)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_or_service_key

# Polymarket API (CLOB Credentials) - Milestone 5+
POLY_WALLET_ADDRESS=0x...
POLY_PRIVATE_KEY=your_private_key
POLY_API_KEY=your_clob_api_key
POLY_SECRET=your_clob_secret
POLY_PASSPHRASE=your_clob_passphrase
POLYGON_RPC_URL=https://polygon-rpc.com

# Notifications - Milestone 9
TELEGRAM_BOT_TOKEN=your_token
TELEGRAM_CHAT_ID=your_chat_id
DISCORD_WEBHOOK_URL=your_webhook
